# Almoner backend secrets — copy to .env (gitignored) and fill in.
# `npm run deploy:testnet` writes these for you. In production, load from a
# secrets manager (AWS/GCP KMS, HashiCorp Vault) — never from a file in the repo.
#
# On Railway: add each of these as a service Variable (Settings → Variables).
# Railway injects $PORT automatically — do NOT set RELAYER_PORT there.

NETWORK=testnet
POOL_CONTRACT_ID=
USDC_TOKEN_ID=

# Organization treasury (production: multisig / HSM, or operator Freighter wallet)
ADMIN_PUBLIC_KEY=
ADMIN_SECRET=

# Relayer — sponsors fresh beneficiary accounts + pays claim fees (zero-gas)
RELAYER_PUBLIC_KEY=
RELAYER_SECRET=

# Auditor / donor view key — beneficiaries encrypt audit memos to the PUBLIC key;
# the SECRET key decrypts them (demo: served at /api/auditor-viewkey; production:
# the donor holds it and it never touches the server).
AUDITOR_PUBLIC_KEY=
AUDITOR_SECRET=

# Optional gate for the privileged org endpoints (/api/program, /api/fund).
# If set, callers must send header `x-operator-key: <this>`.
OPERATOR_KEY=

# Local dev only — the port the backend listens on (Railway provides $PORT).
RELAYER_PORT=8787
